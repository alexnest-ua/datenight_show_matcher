# Base URL for the backend API.
#
# Leave EMPTY for:
#   - local dev (the Vite dev server proxies /api and /health to localhost:8090)
#   - Cloudflare Pages with no backend (the app auto-falls back to DEMO mode)
#
# Set to a backend origin (e.g. https://api.example.com) to force LIVE mode
# against a remote backend. If health passes there, LIVE is preferred.
VITE_API_BASE=
