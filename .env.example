# ─────────────────────────────────────────────────────────────
# DateNight Show Matcher — backend configuration
# Copy to `.env` (cp .env.example .env) and fill in as needed.
# Everything has a sensible default; the app runs with ZERO config
# in offline mock mode (no API key required).
# ─────────────────────────────────────────────────────────────

# Anthropic API key. If absent, the app auto-selects offline MOCK mode.
# Get one at https://console.anthropic.com/  (format: sk-ant-...)
ANTHROPIC_API_KEY=

# Run mode: auto | real | mock
#   auto  -> real when ANTHROPIC_API_KEY is set, otherwise mock  (default)
#   real  -> always call the Claude API (errors if no key)
#   mock  -> always use the deterministic offline mock-LLM (no key, no cost)
APP_MODE=auto

# ── Model selection (overridable) ────────────────────────────
# Analytical agents (orchestrator / profiler / matcher) -> "Sonnet" tier.
# Fast agents (insta reader / streaming checker)         -> "Haiku" tier.
# NOTE: the assignment PDF named claude-3-5-sonnet-20241022 /
# claude-3-5-haiku-20241022 — BOTH were RETIRED by Anthropic (Oct-2025 /
# Feb-2026) and now return HTTP 404. We default to current models.
MODEL_ANALYSIS=claude-sonnet-4-6
MODEL_FAST=claude-haiku-4-5-20251001

# Whether the Insta Reader uses an LLM to synthesize the dump (true)
# or returns the raw mock dump verbatim (false, default — faithful to the
# PDF which says #1 just "imitates" reading).
INSTA_READER_USE_LLM=false

# ── Pipeline behaviour ───────────────────────────────────────
MAX_REPICKS=3              # how many times the matcher may re-pick when nothing is on Netflix/HBO
USER_PLATFORMS=netflix,hbo # subscriptions the user actually has (Prime is ignored per the brief)

# ── HTTP / API ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8090
# Allowed browser origins for CORS (Vite dev + local preview). Comma-separated.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173

# ── Misc ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
REQUEST_TIMEOUT=60
MAX_RETRIES=3
